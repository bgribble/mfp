        "5": {
            "connections": [
                []
            ],
            "do_onload": false,
            "gui_params": {
                "clickchange": false,
                "code": null,
                "connection_info": [],
                "debug": false,
                "default": "",
                "display_type": "text",
                "export_offset_x": 0,
                "export_offset_y": 0,
                "height": 264.0,
                "is_export": false,
                "layername": "Layer 0",
                "max_width": 600,
                "min_height": 12,
                "min_width": 12,
                "no_export": false,
                "obj_args": null,
                "obj_name": "text_007",
                "obj_state": 3,
                "obj_type": "text",
                "panel_enable": false,
                "panel_x": 40.0,
                "panel_y": 307.0,
                "panel_z": 0,
                "patch_x": 40.0,
                "patch_y": 307.0,
                "patch_z": 0,
                "position_x": 40.0,
                "position_y": 307.0,
                "position_z": 0,
                "properties": {},
                "scope": "__patch__",
                "style": {},
                "update_required": true,
                "value": "[bufedit.fx~] is an internal util for\nthe buffer editor.\n\nIt's used with the first arg being the name of the fx patch to use and the second arg trhe number of channels\n\nfor example, \n\n[bufedit.fx~ \"fx.fadein~\", 2]\n\nsignal inputs are\n\n* input level (gain on signal in before fx)\n\n* xfade (0 is all dry, 1 is all wet)\n\n* signal ins 1 to N \n\nSignal inputs and outputs are in the \"FX processing\" layer",
                "width": 587.0
            },
            "initargs": null,
            "midi_filters": null,
            "midi_mode": null,
            "name": "text_007",
            "osc_methods": [],
            "presets": {},
            "properties": {},
            "type": "text",
            "value": "[bufedit.fx~] is an internal util for\nthe buffer editor.\n\nIt's used with the first arg being the name of the fx patch to use and the second arg trhe number of channels\n\nfor example, \n\n[bufedit.fx~ \"fx.fadein~\", 2]\n\nsignal inputs are\n\n* input level (gain on signal in before fx)\n\n* xfade (0 is all dry, 1 is all wet)\n\n* signal ins 1 to N \n\nSignal inputs and outputs are in the \"FX processing\" layer"
        },

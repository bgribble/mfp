            "faust_params": [
                "Attack (ms)",
                "Ratio (1:x)",
                "Release (ms)",
                "Threshold (dB)"
            ],
            "gui_params": {
                "code": {
                    "body": "faust_code = \"\"\"\nimport(\"stdfaust.lib\");\n\n// Compressor parameters\nthresh = hslider(\"Threshold (dB)\", -20, -100, 10, 0.1);\nratio  = hslider(\"Ratio (1:x)\", 4, 1, 20, 0.1);\nattack = hslider(\"Attack (ms)\", 10, 0.1, 1000, 0.1) / 1000;\nrelease = hslider(\"Release (ms)\", 50, 1, 1000, 0.1) / 1000;\n\n// Apply compressor\ngain = co.compression_gain_mono(ratio, thresh, attack, release);\n\nprocess(signal, sidechain) = signal * (sidechain : gain);\n\"\"\"\n\n",
                    "lang": "python"
                },
